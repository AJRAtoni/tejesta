{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign full_width = '100vw'
  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'

  if section.settings.image_behavior == 'ambient'
    assign full_width = '120vw'
    assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

{%- style -%}
  #TejestaRandomBanner-{{ section.id }} {
    visibility: hidden;
  }

  #TejestaRandomBanner-{{ section.id }}.is-ready {
    visibility: visible;
  }

  #TejestaRandomBanner-{{ section.id }} .tejesta-random-banner__option {
    display: none;
  }

  #TejestaRandomBanner-{{ section.id }} .tejesta-random-banner__option.is-active {
    display: block;
  }

  {%- for block in section.blocks -%}
    #Banner-{{ section.id }}-{{ block.id }}::after {
      opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
    }

    {%- if section.settings.image_height == 'adapt' and block.settings.image != blank -%}
      @media screen and (max-width: 749px) {
        #Banner-{{ section.id }}-{{ block.id }}::before,
        #Banner-{{ section.id }}-{{ block.id }} .banner__media::before,
        #Banner-{{ section.id }}-{{ block.id }}:not(.banner--mobile-bottom) .banner__content::before {
          padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;
          content: '';
          display: block;
        }
      }

      @media screen and (min-width: 750px) {
        #Banner-{{ section.id }}-{{ block.id }}::before,
        #Banner-{{ section.id }}-{{ block.id }} .banner__media::before {
          padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;
          content: '';
          display: block;
        }
      }
    {%- endif -%}
  {%- endfor -%}
{%- endstyle -%}

<noscript>
  <style>
    #TejestaRandomBanner-{{ section.id }} {
      visibility: visible;
    }
  </style>
</noscript>

<div
  id="TejestaRandomBanner-{{ section.id }}"
  class="tejesta-random-banner{% if section.settings.show_text_box == false %} section-color--white{% endif %}"
  data-tejesta-random-banner
>
  {%- for block in section.blocks -%}
    <div
      class="tejesta-random-banner__option{% if forloop.first %} is-active{% endif %}"
      data-random-banner-option
      {{ block.shopify_attributes }}
    >
      {%- liquid
        assign has_media = false
        if block.settings.video != blank or block.settings.image != blank
          assign has_media = true
        endif
      -%}
      <div
        id="Banner-{{ section.id }}-{{ block.id }}"
        class="banner banner--content-align-{{ section.settings.desktop_content_alignment }} banner--content-align-mobile-{{ section.settings.mobile_content_alignment }} banner--{{ section.settings.image_height }} banner--homepage-image-banner{% if section.settings.show_text_box == false and has_media %} section-color--white{% endif %}{% if section.settings.image_height == 'adapt' and block.settings.image != blank and block.settings.video == blank %} banner--adapt{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{%- endif -%}{% if section.settings.show_text_box == false %} banner--desktop-transparent{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
      >
        {%- if block.settings.video != blank -%}
          <div class="banner__media banner__media--video media{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
            {{
              block.settings.video
              | video_tag:
                image_size: '3840x',
                autoplay: true,
                loop: true,
                controls: false,
                muted: true,
                playsinline: true
            }}
          </div>
        {%- elsif block.settings.image != blank -%}
          <div class="banner__media media{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
            {%- assign image_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio -%}
            {{
              block.settings.image
              | image_url: width: 3840
              | image_tag:
                width: block.settings.image.width,
                height: image_height,
                sizes: full_width,
                widths: widths,
                fetchpriority: fetch_priority
            }}
          </div>
        {%- else -%}
          <div class="banner__media media placeholder{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <div class="banner__box content-container content-container--full-width-mobile color-{{ section.settings.color_scheme }} gradient">
            {%- if block.settings.heading != blank -%}
              <h2 class="banner__heading inline-richtext {{ block.settings.heading_size }}">
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="banner__text rte {{ block.settings.text_style }}">
                <p>{{ block.settings.text }}</p>
              </div>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <div class="banner__buttons{% if request.page_type == 'index' %} banner__buttons--homepage-cta{% endif %}">
                <a
                  {% if block.settings.button_link == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link }}"
                  {% endif %}
                  class="button{% if request.page_type == 'index' %} button--homepage-cta{% endif %}{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label | escape -}}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  {%- else -%}
    <div class="tejesta-random-banner__option is-active">
      <div class="banner banner--large banner--homepage-image-banner banner--desktop-transparent">
        <div class="banner__media media placeholder">
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      </div>
    </div>
  {%- endfor -%}
</div>

<script>
  (() => {
    const section = document.getElementById('TejestaRandomBanner-{{ section.id }}');
    if (!section) return;

    const options = Array.from(section.querySelectorAll('[data-random-banner-option]'));
    if (!options.length) return;

    const showOption = (selectedOption) => {
      options.forEach((option) => {
        option.classList.toggle('is-active', option === selectedOption);
      });
    };

    const storageKey = 'tejesta-random-banner-daily-index-{{ section.id }}';
    const rotationDuration = 24 * 60 * 60 * 1000;

    const isValidIndex = (index) => Number.isInteger(index) && index >= 0 && index < options.length;

    const getStoredRotation = () => {
      try {
        const storedRotation = JSON.parse(window.localStorage.getItem(storageKey));
        if (!storedRotation || typeof storedRotation !== 'object') return null;

        const index = Number(storedRotation.index);
        const expiresAt = Number(storedRotation.expiresAt);

        if (!isValidIndex(index) || !Number.isFinite(expiresAt)) return null;

        return { index, expiresAt };
      } catch (error) {
        return null;
      }
    };

    const getRandomIndex = (previousIndex = -1) => {
      if (options.length === 1) return 0;

      const availableIndexes = options
        .map((option, index) => index)
        .filter((index) => index !== previousIndex);

      return availableIndexes[Math.floor(Math.random() * availableIndexes.length)];
    };

    const getDailyIndex = () => {
      const now = Date.now();
      const storedRotation = getStoredRotation();

      if (storedRotation && storedRotation.expiresAt > now) {
        return storedRotation.index;
      }

      const selectedIndex = getRandomIndex(storedRotation?.index ?? -1);

      try {
        window.localStorage.setItem(
          storageKey,
          JSON.stringify({
            index: selectedIndex,
            expiresAt: now + rotationDuration,
          })
        );
      } catch (error) {
        // Ignore storage failures and keep the daily hero working.
      }

      return selectedIndex;
    };

    if (!window.Shopify || !window.Shopify.designMode) {
      showOption(options[getDailyIndex()]);
      section.classList.add('is-ready');
      return;
    }

    section.classList.add('is-ready');

    section.addEventListener('shopify:block:select', (event) => {
      const selectedOption = event.target.closest('[data-random-banner-option]');
      if (selectedOption) showOption(selectedOption);
    });
  })();
</script>

{% schema %}
{
