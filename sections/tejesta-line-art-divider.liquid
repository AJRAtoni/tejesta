{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  #TejestaLineArtDivider-{{ section.id }} {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  #TejestaLineArtDivider-{{ section.id }} .tejesta-line-art-divider__image {
    display: block;
    width: min({{ section.settings.divider_width }}vw, {{ settings.page_width }}px);
    max-width: calc(100vw - 32px);
    height: auto;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #TejestaLineArtDivider-{{ section.id }} .tejesta-line-art-divider__image {
      max-width: calc(100vw - 96px);
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div id="TejestaLineArtDivider-{{ section.id }}" class="tejesta-line-art-divider">
    <img
      class="tejesta-line-art-divider__image"
      src="{{ 'tejesta-line-art-divider.png' | asset_url }}"
      width="5389"
      height="127"
      loading="lazy"
      alt=""
    >
  </div>
</div>

{% schema %}
{
  "name": "TEJESTA line divider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "divider_width",
      "min": 70,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Divider width",
      "default": 90
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "TEJESTA line divider"
    }
  ]
}
{% endschema %}
