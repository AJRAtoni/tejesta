{% comment %}
  TEJESTA collection filters inspired by Matsuda.
  Static category taxonomy comes from WEBSITE CATAGORY BREAKDOWN.xlsx.
  Filters run client-side against product card data attributes in main-collection-product-grid.liquid.
{% endcomment %}

{%- assign tejesta_styles = 'DIXON|RAY|GERONIMO|COMANCHE|ARAKI|PARKER|CRAZY HORSE|JPG|CHACON|SEMINOLE|CURTIS|TUTTLE|KEEFFE|OSCEOLA|HOPPER|NOKONI|LENNON|ANNIE-O|SIXTO|SHIPROCK|TAIGA|ERTE|NINETY|HOPKINS' | split: '|' -%}
{%- assign tejesta_collections = 'VAQUERO|RAYGERAKI|ARTESANIA|WINTER 2025|COLLECTION 7|OTHER' | split: '|' -%}
{%- assign tejesta_materials = 'ACETATE|METAL' | split: '|' -%}
{%- assign tejesta_sizes = 'SMALL|MEDIUM|LARGE' | split: '|' -%}
{%- assign tejesta_shapes = 'Geometric|Cat-Eye|Square|Rectangular|Circular|Oval|Round|Wrap|Aviator' | split: '|' -%}

<div class="tejesta-filter-shell page-width" data-tejesta-collection-filters>
  <div class="tejesta-filter-mobile-bar">
    <button class="tejesta-filter-refine button button--secondary" type="button" data-tejesta-filter-open>
      Refine
    </button>
    <div class="tejesta-filter-tags" data-tejesta-filter-tags></div>
  </div>

  <div class="tejesta-filter-panel" data-tejesta-filter-panel>
    <div class="tejesta-filter-panel__header">
      <h2 class="tejesta-filter-panel__title">Refine</h2>
      <button class="tejesta-filter-panel__close" type="button" aria-label="Close filters" data-tejesta-filter-close>
        &times;
      </button>
    </div>

    <div class="tejesta-filter-controls" data-tejesta-filter-controls>
      <div class="tejesta-filter" data-filter-id="style">
        <label class="tejesta-filter__label" for="TejestaFilterStyle">Style</label>
        <select class="tejesta-filter__select" id="TejestaFilterStyle" data-filter-key="style">
          <option value="all">All</option>
          {%- for item in tejesta_styles -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
      </div>

      <div class="tejesta-filter" data-filter-id="collection">
        <label class="tejesta-filter__label" for="TejestaFilterCollection">Collection</label>
        <select class="tejesta-filter__select" id="TejestaFilterCollection" data-filter-key="collection">
          <option value="all">All</option>
          {%- for item in tejesta_collections -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
      </div>

      <div class="tejesta-filter" data-filter-id="material">
        <label class="tejesta-filter__label" for="TejestaFilterMaterial">Material</label>
        <select class="tejesta-filter__select" id="TejestaFilterMaterial" data-filter-key="material">
          <option value="all">All</option>
          {%- for item in tejesta_materials -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
      </div>

      <div class="tejesta-filter" data-filter-id="size">
        <label class="tejesta-filter__label" for="TejestaFilterSize">Size</label>
        <select class="tejesta-filter__select" id="TejestaFilterSize" data-filter-key="size">
          <option value="all">All</option>
          {%- for item in tejesta_sizes -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
      </div>

      <div class="tejesta-filter" data-filter-id="shape">
        <label class="tejesta-filter__label" for="TejestaFilterShape">Shape</label>
        <select class="tejesta-filter__select" id="TejestaFilterShape" data-filter-key="shape">
          <option value="all">All</option>
          {%- for item in tejesta_shapes -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
      </div>
    </div>

    <button class="tejesta-filter-apply button button--primary" type="button" data-tejesta-filter-close>
      See <span data-tejesta-result-count>{{ results.products_count }}</span> products
    </button>
  </div>

  <div class="tejesta-filter-result-info" aria-live="polite">
    <button class="tejesta-filter-reset" type="button" data-tejesta-filter-reset hidden>Reset</button>
    <span class="tejesta-filter-count" data-tejesta-result-label hidden>
      <span data-tejesta-result-count>{{ results.products_count }}</span> results
    </span>
  </div>
</div>
