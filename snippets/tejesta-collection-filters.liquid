{% comment %}
  TEJESTA collection filters.
  Filters run client-side against product card data attributes in main-collection-product-grid.liquid.
{% endcomment %}

{%- assign tejesta_types = 'Sunglasses|Optical' | split: '|' -%}
{%- assign tejesta_collections = 'Vaquero|Raygeraki|Artesania|Winter 2025|Collection 7' | split: '|' -%}
{%- assign tejesta_sizes = 'Small|Medium|Large' | split: '|' -%}
{%- assign tejesta_shapes = 'Rectangular|Cat-Eye|Square|Oval|Circular|Round|Wrap|Aviator' | split: '|' -%}

<div class="tejesta-filter-shell page-width" data-tejesta-collection-filters>
  <div class="tejesta-filter-mobile-bar">
    <button class="tejesta-filter-refine button button--secondary" type="button" data-tejesta-filter-open>
      Refine
    </button>
    <div class="tejesta-filter-tags" data-tejesta-filter-tags></div>
  </div>

  <div class="tejesta-filter-panel" data-tejesta-filter-panel>
    <div class="tejesta-filter-panel__header">
      <h2 class="tejesta-filter-panel__title">Refine</h2>
      <button class="tejesta-filter-panel__close" type="button" aria-label="Close filters" data-tejesta-filter-close>
        &times;
      </button>
    </div>

    <div class="tejesta-filter-controls" data-tejesta-filter-controls>
      <div class="tejesta-filter" data-filter-id="type">
        <label class="tejesta-filter__label" id="TejestaFilterTypeLabel" for="TejestaFilterType">Type</label>
        <select class="tejesta-filter__select" id="TejestaFilterType" data-filter-key="type" tabindex="-1" aria-hidden="true">
          <option value="all">All</option>
          {%- for item in tejesta_types -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
        <button
          class="tejesta-filter__trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="TejestaFilterTypeLabel TejestaFilterTypeCurrent"
          data-filter-trigger
        >
          <span id="TejestaFilterTypeCurrent" data-filter-current>All</span>
          <span class="tejesta-filter__caret" aria-hidden="true"></span>
        </button>
        <div class="tejesta-filter__dropdown" role="listbox" aria-labelledby="TejestaFilterTypeLabel">
          <button class="tejesta-filter__option" type="button" role="option" data-filter-option="all" aria-selected="true">
            All
          </button>
          {%- for item in tejesta_types -%}
            <button class="tejesta-filter__option" type="button" role="option" data-filter-option="{{ item | handleize }}" aria-selected="false">
              {{ item }}
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="tejesta-filter" data-filter-id="collection">
        <label class="tejesta-filter__label" id="TejestaFilterCollectionLabel" for="TejestaFilterCollection">Collection</label>
        <select class="tejesta-filter__select" id="TejestaFilterCollection" data-filter-key="collection" tabindex="-1" aria-hidden="true">
          <option value="all">All</option>
          {%- for item in tejesta_collections -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
        <button
          class="tejesta-filter__trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="TejestaFilterCollectionLabel TejestaFilterCollectionCurrent"
          data-filter-trigger
        >
          <span id="TejestaFilterCollectionCurrent" data-filter-current>All</span>
          <span class="tejesta-filter__caret" aria-hidden="true"></span>
        </button>
        <div class="tejesta-filter__dropdown" role="listbox" aria-labelledby="TejestaFilterCollectionLabel">
          <button class="tejesta-filter__option" type="button" role="option" data-filter-option="all" aria-selected="true">
            All
          </button>
          {%- for item in tejesta_collections -%}
            <button class="tejesta-filter__option" type="button" role="option" data-filter-option="{{ item | handleize }}" aria-selected="false">
              {{ item }}
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="tejesta-filter" data-filter-id="size">
        <label class="tejesta-filter__label" id="TejestaFilterSizeLabel" for="TejestaFilterSize">Size</label>
        <select class="tejesta-filter__select" id="TejestaFilterSize" data-filter-key="size" tabindex="-1" aria-hidden="true">
          <option value="all">All</option>
          {%- for item in tejesta_sizes -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
        <button
          class="tejesta-filter__trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="TejestaFilterSizeLabel TejestaFilterSizeCurrent"
          data-filter-trigger
        >
          <span id="TejestaFilterSizeCurrent" data-filter-current>All</span>
          <span class="tejesta-filter__caret" aria-hidden="true"></span>
        </button>
        <div class="tejesta-filter__dropdown" role="listbox" aria-labelledby="TejestaFilterSizeLabel">
          <button class="tejesta-filter__option" type="button" role="option" data-filter-option="all" aria-selected="true">
            All
          </button>
          {%- for item in tejesta_sizes -%}
            <button class="tejesta-filter__option" type="button" role="option" data-filter-option="{{ item | handleize }}" aria-selected="false">
              {{ item }}
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="tejesta-filter" data-filter-id="shape">
        <label class="tejesta-filter__label" id="TejestaFilterShapeLabel" for="TejestaFilterShape">Shape</label>
        <select class="tejesta-filter__select" id="TejestaFilterShape" data-filter-key="shape" tabindex="-1" aria-hidden="true">
          <option value="all">All</option>
          {%- for item in tejesta_shapes -%}
            <option value="{{ item | handleize }}">{{ item }}</option>
          {%- endfor -%}
        </select>
        <button
          class="tejesta-filter__trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="TejestaFilterShapeLabel TejestaFilterShapeCurrent"
          data-filter-trigger
        >
          <span id="TejestaFilterShapeCurrent" data-filter-current>All</span>
          <span class="tejesta-filter__caret" aria-hidden="true"></span>
        </button>
        <div class="tejesta-filter__dropdown" role="listbox" aria-labelledby="TejestaFilterShapeLabel">
          <button class="tejesta-filter__option" type="button" role="option" data-filter-option="all" aria-selected="true">
            All
          </button>
          {%- for item in tejesta_shapes -%}
            <button class="tejesta-filter__option" type="button" role="option" data-filter-option="{{ item | handleize }}" aria-selected="false">
              {{ item }}
            </button>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <button class="tejesta-filter-apply button button--primary" type="button" data-tejesta-filter-close>
      See <span data-tejesta-result-count>{{ results.products_count }}</span> products
    </button>
  </div>

  <div class="tejesta-filter-result-info" aria-live="polite">
    <button class="tejesta-filter-reset" type="button" data-tejesta-filter-reset hidden>Reset</button>
    <span class="tejesta-filter-count" data-tejesta-result-label hidden>
      <span data-tejesta-result-count>{{ results.products_count }}</span> results
    </span>
  </div>
</div>
