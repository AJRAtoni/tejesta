{% comment %}
  Outputs the TEJESTA client-side filter data attributes for one product.

  Accepts:
  - product: Shopify product object
  - collection: Current collection object
{% endcomment %}

{%- liquid
  assign product_key = product.handle | append: ' ' | append: product.title | downcase
  assign product_type = product.type | downcase
  assign filter_type = 'sunglasses'
  assign filter_collection = 'other'
  assign filter_size = 'all'
  assign filter_shape = 'all'

  if collection.handle == 'optical' or product_type contains 'optical'
    assign filter_type = 'optical'
  elsif product_type contains 'sunglasses' or collection.handle == 'sun'
    assign filter_type = 'sunglasses'
  endif

  for product_collection in product.collections
    if product_collection.handle contains 'optical'
      assign filter_type = 'optical'
    endif
  endfor

  if product_key contains ' rx' or product_key contains '-rx' or product_key contains 'optical'
    assign filter_type = 'optical'
  endif

  if product_key contains 'crazy-horse' or product_key contains 'crazy horse'
    assign filter_collection = 'vaquero'
    assign filter_size = 'small'
    assign filter_shape = 'circular'
  elsif product_key contains 'annie-o' or product_key contains 'annie o'
    assign filter_collection = 'artesania'
    assign filter_size = 'medium'
    assign filter_shape = 'circular'
  elsif product_key contains 'dixon'
    assign filter_collection = 'vaquero'
    assign filter_size = 'small'
    assign filter_shape = 'geometric'
  elsif product_key contains 'geronimo'
    assign filter_collection = 'raygeraki'
    assign filter_size = 'medium'
    assign filter_shape = 'square'
  elsif product_key contains 'comanche'
    assign filter_collection = 'vaquero'
    assign filter_size = 'medium'
    assign filter_shape = 'rectangular'
  elsif product_key contains 'araki'
    assign filter_collection = 'raygeraki'
    assign filter_size = 'small'
    assign filter_shape = 'geometric'
  elsif product_key contains 'parker'
    assign filter_collection = 'vaquero'
    assign filter_size = 'medium'
    assign filter_shape = 'rectangular'
  elsif product_key contains 'chacon'
    assign filter_collection = 'artesania'
    assign filter_size = 'medium'
    assign filter_shape = 'round'
  elsif product_key contains 'seminole'
    assign filter_collection = 'artesania'
    assign filter_size = 'large'
    assign filter_shape = 'rectangular'
  elsif product_key contains 'curtis'
    assign filter_collection = 'artesania'
    assign filter_size = 'medium'
    assign filter_shape = 'rectangular'
  elsif product_key contains 'tuttle'
    assign filter_collection = 'artesania'
    assign filter_size = 'small'
    assign filter_shape = 'cat-eye'
  elsif product_key contains 'keeffe'
    assign filter_collection = 'artesania'
    assign filter_size = 'medium'
    assign filter_shape = 'square'
  elsif product_key contains 'osceola'
    assign filter_collection = 'artesania'
    assign filter_size = 'large'
    assign filter_shape = 'square'
  elsif product_key contains 'hopper'
    assign filter_collection = 'winter-2025'
    assign filter_size = 'medium'
    assign filter_shape = 'wrap'
  elsif product_key contains 'nokoni'
    assign filter_collection = 'winter-2025'
    assign filter_size = 'medium'
    assign filter_shape = 'rectangular'
  elsif product_key contains 'lennon'
    assign filter_collection = 'artesania'
    assign filter_size = 'small'
    assign filter_shape = 'round'
  elsif product_key contains 'sixto'
    assign filter_collection = 'artesania'
    assign filter_size = 'medium'
    assign filter_shape = 'square'
  elsif product_key contains 'shiprock'
    assign filter_collection = 'other'
    assign filter_size = 'small'
    assign filter_shape = 'aviator'
  elsif product_key contains 'taiga'
    assign filter_collection = 'collection-7'
    assign filter_size = 'large'
    assign filter_shape = 'rectangular'
  elsif product_key contains 'erte'
    assign filter_collection = 'collection-7'
    assign filter_size = 'medium'
    assign filter_shape = 'rectangular'
  elsif product_key contains 'ninety'
    assign filter_collection = 'collection-7'
    assign filter_size = 'small'
    assign filter_shape = 'oval'
  elsif product_key contains 'hopkins'
    assign filter_collection = 'collection-7'
    assign filter_size = 'medium'
    assign filter_shape = 'cat-eye'
  elsif product_key contains 'jpg'
    assign filter_collection = 'other'
    assign filter_size = 'small'
    assign filter_shape = 'oval'
  elsif product.handle == 'ray' or product.handle contains 'ray-'
    assign filter_collection = 'raygeraki'
    assign filter_size = 'medium'
    assign filter_shape = 'cat-eye'
  endif
-%}
data-tejesta-filter-type="{{ filter_type }}"
data-tejesta-filter-collection="{{ filter_collection }}"
data-tejesta-filter-size="{{ filter_size }}"
data-tejesta-filter-shape="{{ filter_shape }}"
